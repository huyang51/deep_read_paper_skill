{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} {{SKILL_DIR}}/hooks/session_start.py",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} {{SKILL_DIR}}/hooks/user_prompt_submit.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
